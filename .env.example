# App Configuration
SECRET_KEY=change-me-to-at-least-32-characters-secret-key
DEBUG=true
APP_NAME=MediaFlow

# Database Configuration (Example: postgresql+psycopg://user:pass@localhost:5432/db)
DATABASE_URL=sqlite+aiosqlite:///./database.db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
USE_FAKEREDIS=false

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-at-least-8-characters

# Rate Limits
RATE_LIMIT_GLOBAL_REQUESTS=1000
RATE_LIMIT_GLOBAL_WINDOW=60
RATE_LIMIT_USER_REQUESTS=30
RATE_LIMIT_USER_WINDOW=60
RATE_LIMIT_DOWNLOAD_REQUESTS=10
RATE_LIMIT_DOWNLOAD_WINDOW=60

# Webhook (Optional)
WEBHOOK_BASE_URL=https://your-domain.com
